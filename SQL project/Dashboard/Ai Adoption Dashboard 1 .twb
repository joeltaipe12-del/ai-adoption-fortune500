      <aliases enabled='yes' />
      <column caption='Non Adoptor flag ' datatype='integer' name='[Calculation_0046384105349120]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='1 - [Calculation_2260384680968194]' />
      </column>
      <column caption='Industry highlight ' datatype='string' name='[Calculation_0046384174673921]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [industry_name] = &quot;Logistics&quot; THEN &quot;Highest adoption gap&quot;&#10;ELSE &quot;Other industries&quot;&#10;END' />
      </column>
      <column caption='Industry Count' datatype='integer' name='[Calculation_0046384334430210]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [industry_name] : COUNTD([company_name]) }' />
      </column>
      <column caption='Industry use case' datatype='integer' name='[Calculation_0046384336384003]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [industry_name] , [use_case_name] : COUNTD([company_name]) }' />
      </column>
      <column caption='Highlighted Use Case Label' datatype='string' name='[Calculation_0046384374353924]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [year] = 2025 AND [use_case_name] = &quot;Generative AI&quot; THEN &quot;Generative AI&quot;&#10;ELSEIF [year] = 2025 AND [use_case_name] = &quot;Chatbots&quot; THEN &quot;Chatbots&quot;&#10;ELSEIF [year] = 2025 AND [use_case_name] = &quot;Customer Segmentation&quot; THEN &quot;Customer Segmentation&quot;&#10;END' />
      </column>
      <column caption='Maturity Tier ' datatype='string' name='[Calculation_2260384679759872]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [ai_maturity_score] &gt;= 80 THEN &quot;Leader&quot;&#10;ELSEIF [ai_maturity_score] &gt;= 50 THEN &quot;Adopter&quot;&#10;ELSE &quot;Laggard&quot;&#10;END' />
      </column>
      <column caption='Revenue ' datatype='real' name='[Calculation_2260384680812545]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[revenue_usd]/1000000000' />
      </column>
      <column caption='Ai Adoptor Flag' datatype='integer' name='[Calculation_2260384680968194]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [uses_ai_bool] = TRUE THEN 1 ELSE 0 END' />
      </column>
      <column caption='Uses ai ' datatype='string' name='[Calculation_2260384681472003]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [uses_ai_bool] = TRUE THEN &quot;Yes&quot; ELSE &quot;No&quot; END' />
      </column>
      <column caption='Leader Flag' datatype='integer' name='[Calculation_2260385741737996]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_2260384679759872] = &quot;Leader&quot; THEN 1 ELSE 0 END' />
      </column>
      <column aggregation='Sum' caption='Target Flag ' datatype='integer' name='[Calculation_2765408616685568]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='IF [revenue_usd] &gt; 50000000000&#10;   AND [ai_maturity_score] &lt; 78&#10;   AND [company_type] = &quot;Real&quot;&#10;THEN 1&#10;ELSE 0&#10;END' />
      </column>
      <column caption='Maturity YoY Change' datatype='integer' name='[Calculation_2765408650899458]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED [company_name]: MAX(IF [year] = 2025 AND [company_type] = &quot;Real&quot; THEN [ai_maturity_score] END)}&#10;-&#10;{FIXED [company_name]: MAX(IF [year] = 2024 AND [company_type] = &quot;Real&quot; THEN [ai_maturity_score] END)}' />
      </column>
      <column caption='Highlight Chart Quardrant ' datatype='string' name='[Calculation_2765408665673731]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [company_name] = &quot;Walmart&quot; THEN &quot;Target&quot;&#10;ELSEIF [company_name] = &quot;Amazon&quot; THEN &quot;Riser&quot;&#10;ELSE &quot;Other&quot;&#10;END' />
      </column>
      <column datatype='string' name='[Country (group)]' role='dimension' semantic-role='[Country].[ISO3166_2]' type='nominal'>
        <calculation class='categorical-bin' column='[country_name]' default='&quot;Other&quot;' new-bin='true'>
          <bin default-name='true' value='&quot;China, Japan, South Korea and 1 more&quot;'>
            <value>&quot;China&quot;</value>
            <value>&quot;Japan&quot;</value>
            <value>&quot;South Korea&quot;</value>
            <value>&quot;USA&quot;</value>
          </bin>
        </calculation>
      </column>
      <column caption='ai_adoption_tableau.csv' datatype='table' name='[__tableau_internal_object_id__].[ai_adoption_tableau.csv_B0A9513C9AED4CE8B75C5AB12E82B52B]' role='measure' type='quantitative' />
      <column caption='Ai Maturity Score' datatype='integer' name='[ai_maturity_score]' role='measure' type='quantitative' />
