      <aliases enabled='yes' />
      <column caption='Maturity Tier ' datatype='string' name='[Calculation_2260384679759872]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [ai_maturity_score] &gt;= 80 THEN &quot;Leader&quot;&#10;ELSEIF [ai_maturity_score] &gt;= 50 THEN &quot;Adopter&quot;&#10;ELSE &quot;Laggard&quot;&#10;END' />
      </column>
      <column caption='Revenue ' datatype='real' name='[Calculation_2260384680812545]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[revenue_usd]/1000000000' />
      </column>
      <column caption='Ai Adoptor Flag' datatype='integer' name='[Calculation_2260384680968194]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [uses_ai_bool] = TRUE THEN 1 ELSE 0 END' />
      </column>
      <column caption='Uses ai ' datatype='string' name='[Calculation_2260384681472003]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [uses_ai_bool] = TRUE THEN &quot;Yes&quot; ELSE &quot;No&quot; END' />
      </column>
      <column caption='Leader Flag' datatype='integer' name='[Calculation_2260385741737996]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_2260384679759872] = &quot;Leader&quot; THEN 1 ELSE 0 END' />
      </column>
